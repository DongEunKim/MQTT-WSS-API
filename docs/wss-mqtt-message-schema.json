{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/wss-mqtt-api/message-schema.json",
  "title": "WSS-MQTT API 메시지 스키마",
  "description": "요청(Request), 응답(ACK), 구독 이벤트(SUBSCRIPTION)를 포괄하는 Envelope 스키마",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/ACK" },
    { "$ref": "#/$defs/Subscription" }
  ],
  "$defs": {
    "Request": {
      "type": "object",
      "description": "클라이언트 → API 게이트웨이 요청",
      "required": ["action", "req_id", "topic"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["PUBLISH", "SUBSCRIBE", "UNSUBSCRIBE"],
          "description": "동작 유형"
        },
        "req_id": {
          "type": "string",
          "description": "클라이언트 생성 고유 요청 식별자 (UUID 또는 Sequence ID)"
        },
        "topic": {
          "type": "string",
          "description": "대상 MQTT 토픽 경로. 와일드카드(+, #) 사용 불가"
        },
        "payload": {
          "description": "PUBLISH 시에만 의미 있음. SUBSCRIBE/UNSUBSCRIBE 시 생략 또는 null"
        }
      },
      "additionalProperties": false
    },
    "ACK": {
      "type": "object",
      "description": "API 게이트웨이 → 클라이언트 요청 응답",
      "required": ["event", "req_id", "code"],
      "properties": {
        "event": {
          "const": "ACK",
          "description": "요청 응답 유형"
        },
        "req_id": {
          "type": "string",
          "description": "원본 요청의 req_id와 매핑"
        },
        "code": {
          "type": "integer",
          "enum": [200, 400, 401, 403, 422, 504],
          "description": "HTTP 상태 코드 체계"
        },
        "payload": {
          "description": "에러 상세 메시지 (4xx/5xx 시 선택적으로 포함)"
        }
      },
      "additionalProperties": false
    },
    "Subscription": {
      "type": "object",
      "description": "API 게이트웨이 → 클라이언트 구독 이벤트",
      "required": ["event", "req_id", "topic", "payload"],
      "properties": {
        "event": {
          "const": "SUBSCRIPTION",
          "description": "구독 이벤트 유형"
        },
        "req_id": {
          "type": "string",
          "description": "원본 SUBSCRIBE 요청의 req_id. 상관관계에 사용"
        },
        "topic": {
          "type": "string",
          "description": "수신 데이터의 발행처 토픽"
        },
        "payload": {
          "description": "TGU가 발행한 원본 데이터"
        }
      },
      "additionalProperties": false
    }
  }
}
